# =============================================================================
# IMPORTANTE: al ejecutar `python run.py` solo se lee el archivo `.env`
# en la raíz del proyecto. Si editó `.env.example`, copie o sincronice a `.env`:
#   copy .env.example .env   (CMD)
#   Copy-Item .env.example .env   (PowerShell)
# =============================================================================
SECRET_KEY=cambie-por-una-clave-larga-y-aleatoria

# En qué interfaz escucha Flask (run.py)
# - Para acceder desde OTRAS PCs en la red suele usarse: 0.0.0.0
# - Para solo esta máquina: 127.0.0.1
# - O la IP fija de este equipo si solo quiere ese interfaz (ej. 192.168.20.60)
FLASK_HOST=192.168.20.60
FLASK_PORT=5001
FLASK_DEBUG=true

# URL que verán los usuarios en enlaces (debe coincidir con cómo abren el navegador)
APP_URL=http://192.168.20.60:5001

# Conexión a MySQL (mismas variables que el script de importación CSV)
# Si en Windows tiene variables de entorno globales MYSQL_* o DATABASE_URL,
# run.py carga este .env con prioridad (override) para evitar que queden en 'root'.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=su_clave_mysql_aqui
MYSQL_DATABASE=mtto_equipos

# -----------------------------------------------------------------------------
# Correo SMTP (notificaciones: solicitudes a TIC, confirmación al usuario,
# solicitud atendida, recuperación de contraseña). Ponga MAIL_ENABLED=true
# y complete los datos que le dio el proveedor de correo.
#
# Puede usar MAIL_SERVER o MAIL_HOST (cualquiera de los dos).
# Puerto 465 suele ir con MAIL_USE_SSL=true y MAIL_USE_TLS=false.
# Si el servidor usa certificado autofirmado: MAIL_SSL_VERIFY=false
# -----------------------------------------------------------------------------
# MAIL_ENABLED=true
# MAIL_SERVER=mail.colbeef.com.co
# MAIL_HOST=mail.colbeef.com.co
# MAIL_PORT=465
# MAIL_USE_SSL=true
# MAIL_USE_TLS=false
# MAIL_USERNAME=no-responder-sirt@colbeef.com.co
# MAIL_PASSWORD=su_clave_smtp
# MAIL_DEFAULT_SENDER=no-responder-sirt@colbeef.com.co
# MAIL_FROM=no-responder-sirt@colbeef.com.co
# MAIL_FROM_NAME=Mtto equipos
# MAIL_SSL_VERIFY=true
# MAIL_TIMEOUT=25
# Buzón donde reciben las nuevas solicitudes (por defecto tecnologia@colbeef.com):
# MAIL_NOTIFY_TO=tecnologia@colbeef.com
# Archivos de evidencia (imágenes)
# UPLOAD_RELATIVE=uploads_solicitudes
# MAX_UPLOAD_FILES=12
# MAX_UPLOAD_BYTES_PER_FILE=5242880
# ALLOWED_IMAGE_EXTENSIONS=png,jpg,jpeg,webp,gif
# MAX_CONTENT_LENGTH=41943040

# Minutos sin actividad antes del aviso «¿Tu sesión sigue activa?» (solo usuarios con sesión iniciada)
# SESSION_IDLE_MINUTES=10

# Opcional: URI completa (si se define, tiene prioridad sobre las líneas MYSQL_*)
# DATABASE_URL=mysql+pymysql://admin:clave@127.0.0.1:3306/mtto_equipos?charset=utf8mb4
